#include <winres.h>

VS_VERSION_INFO VERSIONINFO
 FILEVERSION @LIBLOGGER_VERSION_MAJOR@,@LIBLOGGER_VERSION_MINOR@,@LIBLOGGER_VERSION_PATCH@,0
 PRODUCTVERSION @LIBLOGGER_VERSION_MAJOR@,@LIBLOGGER_VERSION_MINOR@,@LIBLOGGER_VERSION_PATCH@,0
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x2L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "@LIBLOGGER_COMPANY_NAME@\0"
            VALUE "FileDescription", "@LIBLOGGER_FILE_DESCRIPTION@\0"
            VALUE "FileVersion", "@LIBLOGGER_VERSION_STRING@\0"
            VALUE "InternalName", "@LIBLOGGER_OUTPUT_BASENAME@\0"
            VALUE "LegalCopyright", "@LIBLOGGER_COPYRIGHT@\0"
            VALUE "OriginalFilename", "@LIBLOGGER_OUTPUT_BASENAME@.dll\0"
            VALUE "ProductName", "@LIBLOGGER_PRODUCT_NAME@\0"
            VALUE "ProductVersion", "@LIBLOGGER_VERSION_STRING@\0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END